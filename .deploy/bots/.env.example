# Octopus bot instance configuration template.
# setup_instance.sh and the Octopus CLI copy this into .deploy/bots/<bot>/.env
# or the user config directory, then fill in deployment-specific values.

BOT_INSTANCE=
BOT_SLUG=
BOT_AGENT_SLUG=
BOT_DISPLAY_NAME=
BOT_AGENT_DISPLAY_NAME=

TELEGRAM_BOT_TOKEN=
BOT_PROVIDER=claude
BOT_MODEL=
BOT_AGENT_MODE=standalone
BOT_COMPACT_MODE=1

BOT_ALLOW_OPEN=0
BOT_ALLOWED_USERS=
BOT_ADMIN_USERS=
BOT_AUTONOMOUS=0
BOT_APPROVAL_MODE=on

BOT_ROLE=
BOT_AGENT_ROLE=
BOT_AGENT_TAGS=
BOT_AGENT_DESCRIPTION=
BOT_SKILLS=

BOT_TIMEOUT_SECONDS=3600
BOT_WORKING_DIR=/home/bot
BOT_DATA_DIR=/home/bot/data
BOT_CREDENTIAL_KEY=

BOT_COMPLETION_WEBHOOK_URL=
