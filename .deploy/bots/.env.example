# Example bot env file written and consumed by ./octopus.
# Copy this only if you need to inspect or bootstrap a bot config manually.

BOT_SLUG=example-bot
BOT_DISPLAY_NAME="Example Bot"
BOT_AGENT_DISPLAY_NAME="Example Bot"
BOT_TELEGRAM_ID=123456789
BOT_TELEGRAM_USERNAME=example_bot
TELEGRAM_BOT_TOKEN=
BOT_PROVIDER=claude

BOT_AGENT_MODE=standalone
BOT_COMPACT_MODE=1
BOT_ALLOW_OPEN=1
BOT_TIMEOUT_SECONDS=3600
BOT_WORKING_DIR=/home/bot
BOT_DATA_DIR=/home/bot/data

# Optional metadata
# BOT_ROLE=
# BOT_AGENT_ROLE=
# BOT_AGENT_TAGS=
# BOT_AGENT_DESCRIPTION=
# BOT_SKILLS=
# BOT_AGENT_CAPABILITIES=
# BOT_ALLOWED_USERS=
# BOT_COMPLETION_WEBHOOK_URL=

# Optional registry mode
# BOT_AGENT_REGISTRY_URL=http://registry:8787
# BOT_AGENT_REGISTRY_ENROLL_TOKEN=

# Optional shared webhook runtime
# BOT_MODE=webhook
# BOT_RUNTIME_MODE=shared
# BOT_WEBHOOK_URL=
# BOT_WEBHOOK_PORT=8443
