# === Instance identity ===
# BOT_INSTANCE=m1                    # set automatically by scripts/run.sh

# === Telegram ===
TELEGRAM_BOT_TOKEN=                  # required — from @BotFather (each instance needs its own token)
BOT_ALLOWED_USERS=                   # required — comma-separated Telegram @usernames and/or numeric IDs
                                     #   e.g. @alice,@bob or 123456789,@alice
                                     #   Tip: send /id to the bot to find your numeric ID
                                     #   Only listed users can interact; everyone else is silently ignored
# BOT_ALLOW_OPEN=0                   # set to 1 to allow ALL users (no auth — not recommended)

# === Provider ===
BOT_PROVIDER=claude                  # "claude" or "codex" — which CLI this instance drives
# BOT_MODEL=                         # optional — uses provider default if empty
                                     #   claude: claude-opus-4-6, claude-sonnet-4-6, etc.
                                     #   codex: gpt-5.4, o3, etc.

# === Common behavior ===
# BOT_WORKING_DIR=/home/user         # cwd for the CLI subprocess (default: $HOME)
# BOT_EXTRA_DIRS=                    # comma-separated additional allowed dirs
# BOT_DATA_DIR=                      # sessions/uploads; default: ~/.telegram-agent-bot/$BOT_INSTANCE
BOT_TIMEOUT_SECONDS=3600             # max seconds per request; default 300 is too short for long generations
# BOT_APPROVAL_MODE=on               # default safe; user can /approval off
# BOT_ROLE=                          # short role description, e.g. "Senior Python engineer"
                                     #   Must not contain " or \ — use <instance>.role.md for complex roles
# BOT_ADMIN_USERS=                   # comma-separated admin usernames/IDs for store management
                                     #   defaults to BOT_ALLOWED_USERS if not set
# BOT_SKILLS=                        # comma-separated default skills for new chats
                                     #   e.g. code-review,testing,debugging
                                     #   Users can change active skills per chat via /skills
# BOT_STREAM_UPDATE_INTERVAL=1.0     # how often to update the progress message (seconds)
# BOT_TYPING_INTERVAL=4.0            # how often to send "typing..." indicator (seconds)

# === Rate limiting (0 = disabled) ===
# BOT_RATE_LIMIT_PER_MINUTE=0        # max requests per user per minute
# BOT_RATE_LIMIT_PER_HOUR=0          # max requests per user per hour

# === Response summarization ===
# BOT_COMPACT_MODE=0                 # summarize long responses by default (user can /compact on|off)
# BOT_SUMMARY_MODEL=claude-haiku-4-5-20251001  # cheap model for summaries

# === Codex-specific (ignored when BOT_PROVIDER=claude) ===
# CODEX_SANDBOX=workspace-write
# CODEX_SKIP_GIT_REPO_CHECK=1
# CODEX_FULL_AUTO=0
# CODEX_DANGEROUS=0                  # mutually exclusive with CODEX_FULL_AUTO
# CODEX_PROFILE=
