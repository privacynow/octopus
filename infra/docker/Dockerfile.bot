# Supported bot image: real provider-enabled (Claude or Codex CLI in image).
# Build with: ./scripts/provider/build_bot_image.sh [claude|codex]  (tags octopus-agent:claude | :codex).
# One shared base; provider-specific install in final stage.

FROM python:3.12-slim AS base
WORKDIR /app

# Bot workspaces need a real build/runtime toolchain because protocol stages may
# compile code, inspect networks, run Java builds, or install project libraries.
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    bind9-dnsutils \
    build-essential \
    ca-certificates \
    cmake \
    curl \
    fonts-liberation \
    git \
    gosu \
    iproute2 \
    iputils-ping \
    jq \
    libasound2t64 \
    libatk-bridge2.0-0t64 \
    libatk1.0-0t64 \
    libatspi2.0-0t64 \
    libcairo2 \
    libcups2t64 \
    libdbus-1-3 \
    libdrm2 \
    libfontconfig1 \
    libfreetype6 \
    libgbm1 \
    libglib2.0-0t64 \
    libgtk-3-0t64 \
    libharfbuzz0b \
    libnspr4 \
    libnss3 \
    libpango-1.0-0 \
    libx11-6 \
    libx11-xcb1 \
    libxcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxext6 \
    libxfixes3 \
    libxkbcommon0 \
    libxrandr2 \
    libxrender1 \
    libxshmfence1 \
    libxtst6 \
    maven \
    netcat-openbsd \
    nodejs \
    npm \
    openjdk-21-jdk-headless \
    pkg-config \
    ripgrep \
    sudo \
    unzip \
    xvfb \
    zip \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY app ./app
COPY octopus_sdk ./octopus_sdk
COPY scripts ./scripts

ARG BOT_PROVIDER=claude
ARG CLAUDE_INSTALL_METHOD=npm
ARG CLAUDE_CLI_NPM_PACKAGE=@anthropic-ai/claude-code@2.1.7
ARG CLAUDE_INSTALL_URL=https://claude.ai/install.sh
ARG CODEX_CLI_NPM_PACKAGE=@openai/codex@0.36.0
RUN if [ "$BOT_PROVIDER" = "claude" ]; then \
      bash /app/scripts/provider/install_provider_claude.sh; \
    elif [ "$BOT_PROVIDER" = "codex" ]; then \
      bash /app/scripts/provider/install_provider_codex.sh; \
    else \
      echo "BOT_PROVIDER must be claude or codex" && exit 1; \
    fi

# Put provider binaries in /usr/local/bin so they work for bot user (auth lives in /home/bot)
RUN cp /root/.local/bin/claude /usr/local/bin/ 2>/dev/null || true; \
    cp /root/.local/bin/codex /usr/local/bin/ 2>/dev/null || true; \
    which "${BOT_PROVIDER}" || (echo "Provider binary ${BOT_PROVIDER} not in PATH after install" && exit 1)

LABEL org.octopus-agent.provider="${BOT_PROVIDER}"

# bot user: persistent home for provider auth (Claude/Codex store state in home)
RUN useradd -m -d /home/bot -u 1000 bot
RUN printf 'bot ALL=(root) NOPASSWD:ALL\n' > /etc/sudoers.d/octopus-bot \
    && chmod 0440 /etc/sudoers.d/octopus-bot
ENV HOME=/home/bot
WORKDIR /home/bot
ENV PYTHONPATH=/app

# entrypoint: chown bot-home to bot (uid 1000) then run as bot (gosu)
RUN chmod +x /app/scripts/docker/docker-entrypoint.sh
ENTRYPOINT ["/app/scripts/docker/docker-entrypoint.sh"]
CMD ["python", "-m", "app.main"]
