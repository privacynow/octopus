cmd_registry() {
  local choice="" url=""
  printf 'Registry:\n'
  if has_local_registry; then
    url="$(registry_ui_url)"
    if registry_is_running; then
      printf '  local      running    %s\n\n' "$url"
      printf '  1. Follow local registry logs\n'
      printf '  2. Stop local registry\n'
      printf '  3. Back\n'
      read -r -p "Choose an option: " choice || return 1
      case "$choice" in
        1) registry_compose logs -f service ;;
        2) registry_compose down --remove-orphans >/dev/null; printf 'Local registry stopped.\n' ;;
        3) return 0 ;;
        *) octopus_error "Choose one of the listed options."; return 1 ;;
      esac
    else
      printf '  local      stopped    %s\n\n' "$url"
      printf '  1. Start local registry\n'
      printf '  2. Back\n'
      read -r -p "Choose an option: " choice || return 1
      case "$choice" in
        1) ensure_local_registry; printf 'Registry UI: %s\n' "$(registry_ui_url)" ;;
        2) return 0 ;;
        *) octopus_error "Choose one of the listed options."; return 1 ;;
      esac
    fi
  else
    printf '  local      not configured\n\n'
    printf '  1. Start local registry\n'
    printf '  2. Back\n'
    read -r -p "Choose an option: " choice || return 1
    case "$choice" in
      1) ensure_local_registry; printf 'Registry UI: %s\n' "$(registry_ui_url)" ;;
      2) return 0 ;;
      *) octopus_error "Choose one of the listed options."; return 1 ;;
    esac
  fi
}

prompt_first_bot_identity() {
  local token result telegram_id username display_name
  while true; do
    read -r -p "Paste your Telegram bot token: " token || return 1
    case "$token" in
      help|\?)
        print_channel_setup_help telegram
        continue
        ;;
    esac
    if [ -z "$token" ]; then
      octopus_error "Telegram bot token is required."
      continue
    fi
    if telegram_token_is_placeholder "$token"; then
      octopus_error "That still looks like a placeholder token. Copy the full token from @BotFather."
      continue
    fi
    if ! telegram_token_format_valid "$token"; then
      octopus_error "Telegram bot tokens look like digits:letters from @BotFather."
      continue
    fi
    if ! result="$(validate_telegram_token "$token")"; then
      octopus_error "Token was rejected by Telegram. Check with @BotFather that the token is correct."
      continue
    fi
    telegram_id="$(sed -n '1p' <<< "$result")"
    username="$(sed -n '2p' <<< "$result")"
    display_name="$(sed -n '3p' <<< "$result")"
    if [ -z "$telegram_id" ] || [ -z "$username" ]; then
      octopus_error "Telegram returned incomplete bot identity. Try again."
      continue
    fi
    display_name="${display_name:-$username}"
    printf 'This token belongs to %s (@%s).\n' "$display_name" "$username"
    FIRST_BOT_TOKEN="$token"
    FIRST_BOT_TELEGRAM_ID="$telegram_id"
    FIRST_BOT_TELEGRAM_USERNAME="$username"
    FIRST_BOT_DISPLAY_NAME="$display_name"
    return 0
  done
}

prompt_provider_choice() {
  local provider=""
  while true; do
    provider="$(prompt_with_default "Provider (claude or codex)" "claude")"
    case "$provider" in
      claude|codex)
        printf '%s\n' "$provider"
        return 0
        ;;
      *)
        octopus_error "Choose 'claude' or 'codex'."
        ;;
    esac
  done
}

prompt_setup_mode_hatch() {
  local choice=""
  while true; do
    read -r -p "Press Enter for quick setup, or type 'full' for advanced options: " choice || return 1
    case "$(printf '%s' "$choice" | tr '[:upper:]' '[:lower:]')" in
      "")
        printf 'quick\n'
        return 0
        ;;
      full)
        printf 'full\n'
        return 0
        ;;
      *)
        octopus_error "Press Enter for quick setup, or type 'full' for advanced options."
        ;;
    esac
  done
}

ensure_provider_image_ready() {
  local provider="$1" need_build=0 current_rev="" built_rev=""
  if ! docker image inspect "octopus-agent:$provider" >/dev/null 2>&1; then
    need_build=1
  elif [ -f .bot-image-build-rev ]; then
    current_rev="$(git rev-parse HEAD 2>/dev/null || true)"
    built_rev="$(cat .bot-image-build-rev 2>/dev/null || true)"
    if [ -n "$current_rev" ] && [ -n "$built_rev" ] && [ "$current_rev" != "$built_rev" ]; then
      need_build=1
    fi
  fi
  if [ "$need_build" -eq 1 ]; then
    printf 'Building bot image for %s...\n' "$provider"
    "$REPO_DIR/scripts/provider/build_bot_image.sh" "$provider"
  fi
}

ensure_provider_auth_ready() {
  local provider="$1"

  # Fast check: do auth files already exist on disk?
  if provider_has_auth_files "$provider"; then
    update_provider_auth_hint "$provider" "true"
    return 0
  fi

  # No auth files — need to run the login flow.
  octopus_error "Provider authentication is required. Starting the login flow now."
  if ! provider_compose "$provider" run --rm bot-provider sh /app/scripts/provider/container_provider_login.sh; then
    octopus_error "Provider login did not complete. Finish login, then run ./octopus again."
    return 1
  fi

  # After login, check auth files again (fast, no API ping).
  if provider_has_auth_files "$provider"; then
    update_provider_auth_hint "$provider" "true"
    return 0
  fi

  octopus_error "Provider authentication was detected inside the login container but did not persist to .deploy/provider-auth/$provider."
  octopus_error "Finish login again. If this repeats, the provider is writing auth outside the shared mount."
  return 1
}

reset_bot_setup_overrides() {
  BOT_SETUP_ROLE=""
  BOT_SETUP_TAGS=""
  BOT_SETUP_DESCRIPTION=""
  BOT_SETUP_SKILLS=""
  BOT_SETUP_ALLOWED_USERS=""
  BOT_SETUP_TIMEOUT_SECONDS="3600"
  BOT_SETUP_WORKING_DIR="/home/bot"
  BOT_SETUP_COMPLETION_WEBHOOK_URL=""
  NEW_BOT_SETUP_MODE=""
  REGISTRY_TARGET_KIND="standalone"
  REGISTRY_TARGET_URL=""
  REGISTRY_TARGET_TOKEN=""
  REGISTRY_TARGET_SCOPE=""
}

prompt_timeout_seconds_value() {
  local current="${1:-3600}" value=""
  while true; do
    value="$(prompt_with_default "Timeout seconds" "$current")"
    case "$value" in
      ''|*[!0-9]*)
        octopus_error "Timeout must be a whole number of seconds."
        ;;
      0)
        octopus_error "Timeout must be greater than zero."
        ;;
      *)
        printf '%s\n' "$value"
        return 0
        ;;
    esac
  done
}

prompt_port_value() {
  local current="${1:-8443}" value=""
  while true; do
    value="$(prompt_with_default "Webhook port" "$current")"
    case "$value" in
      ''|*[!0-9]*)
        octopus_error "Webhook port must be a whole number."
        ;;
      0)
        octopus_error "Webhook port must be greater than zero."
        ;;
      *)
        printf '%s\n' "$value"
        return 0
        ;;
    esac
  done
}

prompt_allowed_users_value() {
  local current="${1:-}" value=""
  if [ -n "$current" ]; then
    read -r -p "Allowed users (blank = open) [$current]: " value || return 1
    printf '%s\n' "$value"
    return 0
  fi
  read -r -p "Allowed users (blank = open): " value || return 1
  printf '%s\n' "$value"
}

prompt_full_bot_setup_options() {
  local registry_choice=""
  BOT_SETUP_ROLE="$(prompt_with_default "Role" "$BOT_SETUP_ROLE")"
  BOT_SETUP_TAGS="$(prompt_with_default "Tags (comma-separated)" "$BOT_SETUP_TAGS")"
  BOT_SETUP_DESCRIPTION="$(prompt_with_default "Description" "$BOT_SETUP_DESCRIPTION")"
  BOT_SETUP_SKILLS="$(prompt_with_default "Skills (comma-separated)" "$BOT_SETUP_SKILLS")"
  BOT_SETUP_ALLOWED_USERS="$(prompt_allowed_users_value "$BOT_SETUP_ALLOWED_USERS")" || return 1
  BOT_SETUP_WORKING_DIR="$(prompt_with_default "Working directory" "$BOT_SETUP_WORKING_DIR")"
  BOT_SETUP_TIMEOUT_SECONDS="$(prompt_timeout_seconds_value "$BOT_SETUP_TIMEOUT_SECONDS")"
  while true; do
    registry_choice="$(prompt_with_default "Standalone or Registry" "standalone")"
    case "$(printf '%s' "$registry_choice" | tr '[:upper:]' '[:lower:]')" in
      standalone)
        REGISTRY_TARGET_KIND="standalone"
        REGISTRY_TARGET_URL=""
        REGISTRY_TARGET_TOKEN=""
        break
        ;;
      registry)
        if has_local_registry; then
          prompt_registry_target local_existing || return 1
        else
          prompt_registry_target local_new || return 1
        fi
        break
        ;;
      *)
        octopus_error "Choose 'standalone' or 'registry'."
        ;;
    esac
  done
  BOT_SETUP_COMPLETION_WEBHOOK_URL="$(prompt_with_default "Completion webhook URL" "$BOT_SETUP_COMPLETION_WEBHOOK_URL")"
}

prepare_new_bot_setup() {
  local mode="${1:-quick}" existing_slug=""
  local telegram_id="" username="" display_name="" token=""
  ensure_deploy_dirs
  reset_bot_setup_overrides
  prompt_first_bot_identity || return 1
  telegram_id="$FIRST_BOT_TELEGRAM_ID"
  username="$FIRST_BOT_TELEGRAM_USERNAME"
  display_name="$FIRST_BOT_DISPLAY_NAME"
  token="$FIRST_BOT_TOKEN"

  existing_slug="$(find_bot_slug_by_telegram_id "$telegram_id" || true)"
  if [ -n "$existing_slug" ]; then
    if bot_is_running "$existing_slug"; then
      octopus_error "This Telegram bot is already running as '$existing_slug'. Run ./octopus to manage the existing bot."
      return 1
    fi
    # Bot env exists but setup never completed (image build / auth / doctor
    # failed on a previous run). Resume setup for the existing slug instead
    # of re-asking all prompts.
    printf 'Resuming incomplete setup for %s...\n' "$existing_slug"
    local provider
    provider="$(read_bot_env_value BOT_PROVIDER "$(bot_env_file "$existing_slug")")"
    ensure_provider_image_ready "${provider:-claude}" || return 1
    ensure_provider_auth_ready "${provider:-claude}" || return 1
    ensure_network || return 1
    run_bot_doctor_until_ready "$existing_slug" || return 1
    start_bot_until_running "$existing_slug" || return 1
    local existing_username
    existing_username="$(read_bot_env_value BOT_TELEGRAM_USERNAME "$(bot_env_file "$existing_slug")")"
    print_first_bot_success "${existing_username:-$existing_slug}"
    exit 0
  fi

  NEW_BOT_SLUG="$(normalize_slug "$username")"
  NEW_BOT_SLUG="${NEW_BOT_SLUG:-bot}"
  if [ -d ".deploy/bots/$NEW_BOT_SLUG" ]; then
    octopus_error "A different bot already uses the local slug '$NEW_BOT_SLUG'. Remove that bot or choose a different Telegram bot token."
    return 1
  fi

  NEW_BOT_TELEGRAM_ID="$telegram_id"
  NEW_BOT_TELEGRAM_USERNAME="$username"
  NEW_BOT_DISPLAY_NAME="$display_name"
  NEW_BOT_TOKEN="$token"
  NEW_BOT_PROVIDER="$(prompt_provider_choice)"
  NEW_BOT_SETUP_MODE="$mode"

  if [ "$mode" = "quick" ]; then
    NEW_BOT_SETUP_MODE="$(prompt_setup_mode_hatch)" || return 1
  fi

  if [ "$NEW_BOT_SETUP_MODE" = "full" ]; then
    prompt_full_bot_setup_options || return 1
  fi
}

write_first_bot_env() {
  local slug="$1" telegram_id="$2" username="$3" display_name="$4" token="$5" provider="$6"
  local env_file bot_dir
  local role="${BOT_SETUP_ROLE:-}" tags="${BOT_SETUP_TAGS:-}" description="${BOT_SETUP_DESCRIPTION:-}"
  local skills="${BOT_SETUP_SKILLS:-}" allowed_users="${BOT_SETUP_ALLOWED_USERS:-}"
  local timeout_seconds="${BOT_SETUP_TIMEOUT_SECONDS:-3600}" working_dir="${BOT_SETUP_WORKING_DIR:-/home/bot}"
  local completion_webhook_url="${BOT_SETUP_COMPLETION_WEBHOOK_URL:-}"
  local credential_key="${BOT_SETUP_CREDENTIAL_KEY:-}"
  bot_dir=".deploy/bots/$slug"
  env_file="$bot_dir/.env"
  mkdir -p "$bot_dir"
  if [ -z "$credential_key" ]; then
    credential_key="$(python3 -c 'import secrets; print(secrets.token_urlsafe(32))')"
  fi
  {
    write_env_assignment_line BOT_INSTANCE "$slug"
    write_env_assignment_line BOT_SLUG "$slug"
    write_env_assignment_line BOT_AGENT_SLUG "$slug"
    write_env_assignment_line BOT_TELEGRAM_ID "$telegram_id"
    write_env_assignment_line BOT_TELEGRAM_USERNAME "$username"
    write_env_assignment_line BOT_DISPLAY_NAME "$display_name"
    write_env_assignment_line BOT_AGENT_DISPLAY_NAME "$display_name"
    write_env_assignment_line TELEGRAM_BOT_TOKEN "$token"
    write_env_assignment_line BOT_PROVIDER "$provider"
    write_env_assignment_line BOT_AGENT_MODE "standalone"
    write_env_assignment_line BOT_COMPACT_MODE "1"
    if [ -n "$role" ]; then
      write_env_assignment_line BOT_ROLE "$role"
      write_env_assignment_line BOT_AGENT_ROLE "$role"
    fi
    if [ -n "$tags" ]; then
      write_env_assignment_line BOT_AGENT_TAGS "$tags"
    fi
    if [ -n "$description" ]; then
      write_env_assignment_line BOT_AGENT_DESCRIPTION "$description"
    fi
    if [ -n "$skills" ]; then
      write_env_assignment_line BOT_SKILLS "$skills"
      write_env_assignment_line BOT_AGENT_CAPABILITIES "$skills"
    fi
    if [ -n "$allowed_users" ]; then
      write_env_assignment_line BOT_ALLOWED_USERS "$allowed_users"
      write_env_assignment_line BOT_ALLOW_OPEN "0"
    else
      write_env_assignment_line BOT_ALLOW_OPEN "1"
    fi
    write_env_assignment_line BOT_TIMEOUT_SECONDS "$timeout_seconds"
    write_env_assignment_line BOT_WORKING_DIR "$working_dir"
    write_env_assignment_line BOT_DATA_DIR "/home/bot/data"
    write_env_assignment_line BOT_CREDENTIAL_KEY "$credential_key"
    if [ -n "$completion_webhook_url" ]; then
      write_env_assignment_line BOT_COMPLETION_WEBHOOK_URL "$completion_webhook_url"
    fi
  } > "$env_file"
  restrict_secret_file_permissions "$env_file"
}

prompt_rejected_telegram_token_repair() {
  local slug="$1" env_file current_token new_token
  env_file="$(bot_env_file "$slug")"
  current_token="$(read_bot_env_value TELEGRAM_BOT_TOKEN "$env_file")"
  new_token="$(prompt_channel_token_with_help \
    telegram \
    "Paste a replacement Telegram bot token" \
    "$current_token" \
    "Telegram rejected the bot token. Check with @BotFather that it is correct." \
    0)" || return 1
  upsert_env_file_value TELEGRAM_BOT_TOKEN "$new_token" "$env_file"
  return 0
}

run_bot_doctor() {
  local slug="$1"
  shift || true
  bot_compose "$slug" run --rm bot python -m app.main --doctor "$@" 2>&1
}

run_bot_doctor_until_ready() {
  local slug="$1" doctor_output=""
  while true; do
    if doctor_output="$(run_bot_doctor "$slug")"; then
      return 0
    fi
    print_doctor_output_for_operator "$doctor_output"
    if doctor_output_has_token_rejection "$doctor_output"; then
      if prompt_rejected_telegram_token_repair "$slug"; then
        octopus_error "Re-running the health check with the updated Telegram token."
        continue
      fi
    fi
    octopus_error "Full app health check failed. Fix the issue above, then run ./octopus again."
    return 1
  done
}

start_bot_until_running() {
  local slug="$1" doctor_output=""
  while true; do
    bot_compose "$slug" up -d bot >/dev/null
    sleep 5
    if bot_is_running "$slug"; then
      return 0
    fi
    octopus_error "Bot failed to stay up after startup."
    doctor_output="$(run_bot_doctor "$slug" || true)"
    print_doctor_output_for_operator "$doctor_output"
    if doctor_output_has_token_rejection "$doctor_output"; then
      if prompt_rejected_telegram_token_repair "$slug"; then
        octopus_error "Retrying startup with the updated Telegram token."
        continue
      fi
    fi
    octopus_error "Could not start the bot cleanly. Review the health output above, then run ./octopus again."
    return 1
  done
}

restart_bot_service() {
  local slug="$1"
  bot_compose "$slug" stop bot >/dev/null 2>&1 || true
  start_bot_until_running "$slug"
}

current_allowed_users_value() {
  local slug="$1"
  read_bot_env_value BOT_ALLOWED_USERS "$(bot_env_file "$slug")"
}

current_allowed_users_display() {
  local slug="$1" allowed_users=""
  allowed_users="$(current_allowed_users_value "$slug")"
  if [ -n "$allowed_users" ]; then
    printf '%s\n' "$allowed_users"
    return 0
  fi
  printf 'open\n'
}

offer_restart_if_running() {
  local slug="$1" answer=""
  if ! bot_is_running "$slug"; then
    return 0
  fi
  read -r -p "Restart the bot now to apply this change? [Y/n] " answer || return 0
  case "$(printf '%s' "$answer" | tr '[:upper:]' '[:lower:]')" in
    ""|y|yes)
      restart_bot_service "$slug"
      ;;
  esac
}

open_bot_env_in_editor() {
  local slug="$1" env_file=""
  env_file="$(bot_env_file "$slug")"
  if [ -n "${EDITOR:-}" ]; then
    "$EDITOR" "$env_file"
    return $?
  fi
  printf 'Config file: %s\n' "$env_file"
}

edit_bot_settings_menu() {
  local slug="$1" choice="" env_file="" display_name="" provider="" mode="" role="" tags="" allowed_users="" timeout=""
  env_file="$(bot_env_file "$slug")"
  while true; do
    display_name="$(bot_display_name "$slug")"
    provider="$(get_bot_provider "$env_file")"
    mode="$(bot_mode_label "$slug")"
    role="$(read_bot_env_value BOT_ROLE "$env_file")"
    tags="$(read_bot_env_value BOT_AGENT_TAGS "$env_file")"
    allowed_users="$(current_allowed_users_display "$slug")"
    timeout="$(read_bot_env_value BOT_TIMEOUT_SECONDS "$env_file")"
    printf 'Current settings for %s:\n' "$(bot_identity_label "$slug")"
    printf '  Display name:  %s\n' "${display_name:-$slug}"
    printf '  Provider:      %s\n' "$provider"
    printf '  Mode:          %s\n' "$mode"
    printf '  Role:          %s\n' "${role:-"(not set)"}"
    printf '  Timeout:       %ss\n\n' "${timeout:-3600}"
    printf 'What would you like to change?\n'
    printf '  1. Display name\n'
    printf '  2. Role\n'
    printf '  3. Tags\n'
    printf '  4. Allowed users\n'
    printf '  5. Timeout\n'
    printf '  6. Open full config in editor\n'
    printf '  7. Back\n'
    read -r -p "Choose an option: " choice || return 1
    case "$choice" in
      1)
        display_name="$(prompt_with_default "Display name" "${display_name:-$slug}")"
        upsert_env_file_value BOT_DISPLAY_NAME "$display_name" "$env_file"
        upsert_env_file_value BOT_AGENT_DISPLAY_NAME "$display_name" "$env_file"
        offer_restart_if_running "$slug"
        printf '\n'
        ;;
      2)
        role="$(prompt_with_default "Role" "$role")"
        upsert_env_file_value BOT_ROLE "$role" "$env_file"
        upsert_env_file_value BOT_AGENT_ROLE "$role" "$env_file"
        offer_restart_if_running "$slug"
        printf '\n'
        ;;
      3)
        tags="$(prompt_with_default "Tags (comma-separated)" "$tags")"
        upsert_env_file_value BOT_AGENT_TAGS "$tags" "$env_file"
        offer_restart_if_running "$slug"
        printf '\n'
        ;;
      4)
        allowed_users="$(prompt_allowed_users_value "$(current_allowed_users_value "$slug")")" || return 1
        if [ -n "$allowed_users" ]; then
          upsert_env_file_value BOT_ALLOWED_USERS "$allowed_users" "$env_file"
          upsert_env_file_value BOT_ALLOW_OPEN "0" "$env_file"
        else
          remove_env_file_value BOT_ALLOWED_USERS "$env_file"
          upsert_env_file_value BOT_ALLOW_OPEN "1" "$env_file"
        fi
        offer_restart_if_running "$slug"
        printf '\n'
        ;;
      5)
        timeout="$(prompt_timeout_seconds_value "${timeout:-3600}")"
        upsert_env_file_value BOT_TIMEOUT_SECONDS "$timeout" "$env_file"
        offer_restart_if_running "$slug"
        printf '\n'
        ;;
      6)
        open_bot_env_in_editor "$slug"
        printf '\n'
        ;;
      7)
        return 0
        ;;
      *)
        octopus_error "Choose one of the listed options."
        ;;
    esac
  done
}

prompt_webhook_url_value() {
  local current="${1:-}" value=""
  while true; do
    value="$(prompt_with_default "Webhook URL" "$current")"
    case "$value" in
      https://*)
        printf '%s\n' "$value"
        return 0
        ;;
      "")
        octopus_error "Webhook URL is required."
        ;;
      *)
        octopus_error "Webhook URL must start with https://."
        ;;
    esac
  done
}

configure_webhook_mode_flow() {
  local slug="" env_file="" webhook_url="" webhook_port=""
  slug="$(resolve_bot_slug "${1:-}")" || return 1
  env_file="$(bot_env_file "$slug")"
  webhook_url="$(prompt_webhook_url_value "$(read_bot_env_value BOT_WEBHOOK_URL "$env_file")")" || return 1
  webhook_port="$(prompt_port_value "$(read_bot_env_value BOT_WEBHOOK_PORT "$env_file")")"
  upsert_env_file_value BOT_MODE "webhook" "$env_file"
  upsert_env_file_value BOT_RUNTIME_MODE "shared" "$env_file"
  upsert_env_file_value BOT_PROCESS_ROLE "all" "$env_file"
  upsert_env_file_value BOT_WEBHOOK_URL "$webhook_url" "$env_file"
  upsert_env_file_value BOT_WEBHOOK_LISTEN "0.0.0.0" "$env_file"
  upsert_env_file_value BOT_WEBHOOK_PORT "$webhook_port" "$env_file"
  printf 'Webhook mode settings saved for %s.\n' "$slug"
  printf 'Use the shared runtime deployment when you are ready to run webhook mode.\n'
  offer_restart_if_running "$slug"
}

advanced_menu() {
  local choice=""
  while true; do
    printf 'Advanced:\n'
    printf '  1. Add a bot with full setup\n'
    printf '  2. Configure webhook mode\n'
    printf '  3. Back\n'
    read -r -p "Choose an option: " choice || return 1
    case "$choice" in
