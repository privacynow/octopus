  if [ "${REGISTRY_TARGET_KIND:-standalone}" != "standalone" ]; then
    verify_registry_enrollment "$NEW_BOT_SLUG" "$registry_id" || return 1
  fi
  print_first_bot_success "$NEW_BOT_TELEGRAM_USERNAME"
  if [ "${REGISTRY_TARGET_KIND:-standalone}" != "standalone" ]; then
    print_registry_connection_success "$NEW_BOT_SLUG" "$REGISTRY_TARGET_KIND" "$REGISTRY_TARGET_URL"
  fi
}

first_bot_flow() {
  local mode="${1:-quick}"
  local registry_id=""
  prepare_new_bot_setup "$mode" || return 1
  # Write env FIRST so the user's input is saved. If the image build
  # or auth step fails, the next ./octopus run finds this bot and
  # resumes from the build step instead of re-asking for everything.
  write_first_bot_env "$NEW_BOT_SLUG" "$NEW_BOT_TELEGRAM_ID" "$NEW_BOT_TELEGRAM_USERNAME" "$NEW_BOT_DISPLAY_NAME" "$NEW_BOT_TOKEN" "$NEW_BOT_PROVIDER" || return 1
