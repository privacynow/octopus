#!/usr/bin/env bash
set -euo pipefail

OCTOPUS_SCRIPT="${BASH_SOURCE[0]:-$0}"
REPO_DIR="$(cd "$(dirname "$OCTOPUS_SCRIPT")" && pwd)"
cd "$REPO_DIR"

PYTHON_BIN="${PYTHON:-}"
if [ -z "$PYTHON_BIN" ] && [ -x "$REPO_DIR/.venv/bin/python" ]; then
  PYTHON_BIN="$REPO_DIR/.venv/bin/python"
fi
if [ -z "$PYTHON_BIN" ]; then
  PYTHON_BIN="$REPO_DIR/.venv/bin/python"
fi

if [ ! -x "$PYTHON_BIN" ]; then
  if ! command -v python3 >/dev/null 2>&1; then
    echo "python3 is required to bootstrap Octopus." >&2
    exit 1
  fi
  echo "Bootstrapping .venv for Octopus..." >&2
  python3 -m venv "$REPO_DIR/.venv"
  "$REPO_DIR/.venv/bin/pip" install -q -r "$REPO_DIR/requirements.txt"
  PYTHON_BIN="$REPO_DIR/.venv/bin/python"
fi

exec "$PYTHON_BIN" -m app.octopus_cli "$@"
