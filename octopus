add_bot_flow() {
  local mode="${1:-quick}"
  local registry_id=""
  prepare_new_bot_setup "$mode" || return 1
  if [ "${NEW_BOT_SETUP_MODE:-$mode}" = "quick" ]; then
    prompt_new_bot_registry_target || return 1
  fi
  write_first_bot_env "$NEW_BOT_SLUG" "$NEW_BOT_TELEGRAM_ID" "$NEW_BOT_TELEGRAM_USERNAME" "$NEW_BOT_DISPLAY_NAME" "$NEW_BOT_TOKEN" "$NEW_BOT_PROVIDER" || return 1
  ensure_provider_image_ready "$NEW_BOT_PROVIDER" || return 1
  ensure_provider_auth_ready "$NEW_BOT_PROVIDER" || return 1
  ensure_network || return 1
  if [ "${REGISTRY_TARGET_KIND:-standalone}" != "standalone" ]; then
    registry_id="$(derive_registry_connection_id "$NEW_BOT_SLUG" "$REGISTRY_TARGET_KIND" "$REGISTRY_TARGET_URL")"
